---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialButtons from "../components/SocialButtons.astro";
import ArticlePreview from "../components/ArticlePreview.astro";
import global from "../data/global.json";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
---

<BaseLayout isHomepage>
  <!-- Hero -->
  <header class="py-6 bg-gray-100 dark:bg-gray-800">
    <div class="container">
      <a href="/" class="inline-flex flex-row items-center">
        <div
          class="w-14 md:w-16 h-14 md:h-16 bg-primary-200 dark:bg-primary-900 rounded-full"
        >
        </div>
        <h1
          class="font-bold -ml-8 md:-ml-10 text-2xl md:text-3xl text-gray-800 dark:text-gray-200 hover:text-black dark:hover:text-white"
        >
          Rémi de Juvigny
        </h1>
      </a>
      <section
        class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 mt-6 flex flex-col gap-3 [&_a]:underline [&_a]:decoration-primary-300 dark:[&_a]:decoration-primary-700 [&_a]:decoration-[3px]"
      >
        <p>I'm a Product Engineer from France. I build open-source apps for developers. After five years at Strapi, I'm now working on <a href="https://camox.ai" target="_blank">Camox</a>, an agent-native CMS framework.</p>
        <p>I write about making products for the web, using technologies like TypeScript and AI.</p>
      </section>
      <div class="mt-6">
        <SocialButtons socialNetworks={global.footerSocialNetworks} />
      </div>
    </div>
  </header>

  <!-- Blog -->
  <section class="container py-12">
    <p class="uppercase tracking-wide text-blog-500 font-bold mb-6 text-lg">
      Writing
    </p>
    <div class="flex flex-col gap-8">
      {
        posts.map((post) => (
          <ArticlePreview
            title={post.data.title}
            slug={post.data.slug}
            description={post.data.description}
          />
        ))
      }
    </div>
    <a
      href="/blog"
      class="mt-6 px-4 py-2 text-blog-800 dark:text-blog-100 bg-blog-200 dark:bg-blog-800 text-lg font-semibold rounded-lg inline-block hover:shadow"
    >
      All articles
      <svg
        class="inline -mt-[2px] ml-1"
        width="1em"
        height="1em"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
          points="12 5 19 12 12 19"></polyline></svg
      >
    </a>
  </section>

  <!-- Work -->
  <section class="container py-12">
    <p class="uppercase tracking-wide font-bold mb-6 text-lg text-blue-400 dark:text-blue-500">
      Work
    </p>
    <p class="md:text-lg text-gray-700 dark:text-gray-300">
      I'm building Camox full time.
    </p>
    <p class="md:text-lg text-gray-700 dark:text-gray-300 mt-4">
      Camox is my take on what a next-gen CMS should look like. One that unleashes the power of coding agents without generating slop. One that is opinionated, extensible, fully type-safe, all while providing full visual editing.
    </p>
    <p class="md:text-lg text-gray-700 dark:text-gray-300 mt-4">
      Previously engineer at Strapi, where I worked on growing the ecosystem, and building content management features like History and Preview.
    </p>
    <a
      href="https://camox.ai"
      target="_blank"
      class="mt-6 px-4 py-2 text-blue-800 dark:text-blue-100 bg-blue-200 dark:bg-blue-800 text-lg font-semibold rounded-lg inline-block hover:shadow"
    >
      Visit camox.ai
      <svg
        class="inline -mt-[2px] ml-1"
        width="1em"
        height="1em"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
          points="12 5 19 12 12 19"></polyline></svg
      >
    </a>
  </section>
</BaseLayout>
