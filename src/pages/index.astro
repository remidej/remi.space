---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialButtons from "../components/SocialButtons.astro";
import ArticlePreview from "../components/ArticlePreview.astro";
import global from "../data/global.json";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
---

<BaseLayout isHomepage>
  <!-- Hero -->
  <header class="py-6 bg-gray-100 dark:bg-gray-800">
    <div class="container">
      <a href="/" class="inline-flex flex-row items-center">
        <div
          class="w-14 md:w-16 h-14 md:h-16 bg-primary-200 dark:bg-primary-900 rounded-full"
        >
        </div>
        <h1
          class="font-bold -ml-8 md:-ml-10 text-2xl md:text-3xl text-gray-800 dark:text-gray-200 hover:text-black dark:hover:text-white"
        >
          Rémi de Juvigny
        </h1>
      </a>
      <section
        class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 mt-6 flex flex-col gap-3 [&_a]:underline [&_a]:decoration-primary-300 dark:[&_a]:decoration-primary-700 [&_a]:decoration-[3px]"
      >
        <p>I'm a software engineer based in Paris. I currently work at <a href="https://strapi.io" target="_blank">Strapi</a>, building the leading open-source headless CMS.</p>
        <p>I love building things for the web and sharing what I learn along the way.</p>
      </section>
      <div class="mt-6">
        <SocialButtons socialNetworks={global.footerSocialNetworks} />
      </div>
    </div>
  </header>

  <!-- Blog -->
  <section class="container py-12">
    <p class="uppercase tracking-wide text-blog-500 font-bold mb-6 text-lg">
      From the blog
    </p>
    <div class="flex flex-col gap-8">
      {
        posts.map((post) => (
          <ArticlePreview
            title={post.data.title}
            slug={post.data.slug}
            description={post.data.description}
          />
        ))
      }
    </div>
    <a
      href="/blog"
      class="mt-6 px-4 py-2 text-blog-800 dark:text-blog-100 bg-blog-200 dark:bg-blog-800 text-lg font-semibold rounded-lg inline-block hover:shadow"
    >
      All articles
      <svg
        class="inline -mt-[2px] ml-1"
        width="1em"
        height="1em"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
          points="12 5 19 12 12 19"></polyline></svg
      >
    </a>
  </section>

  <!-- Work -->
  <section class="container py-12">
    <p class="uppercase tracking-wide font-bold text-lg text-blue-400 dark:text-blue-500">
      Work
    </p>
    <div
      class:list={[
        "flex flex-col gap-3 md:text-lg text-gray-700 dark:text-gray-300 mt-6",
        "[&_ul]:list-disc [&_ul]:list-inside [&_ul]:flex [&_ul]:flex-col [&_ul]:gap-2",
        "marker:text-blue-500 dark:marker:text-blue-400",
      ]}
    >
      <ul>
        <li><strong>Strapi</strong> — Software engineer since 2020. Building the leading open-source headless CMS.</li>
        <li><strong>HETIC</strong> — Taught web development to master's students in 2021.</li>
        <li><strong>Revolt Influence</strong> — Fullstack developer in 2019. Built an influencer marketing platform.</li>
        <li><strong>MadKudu</strong> — Frontend engineering intern in San Francisco, 2018.</li>
      </ul>
    </div>
  </section>
</BaseLayout>
