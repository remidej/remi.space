---
import HomeHero from "./slices/HomeHero.astro";
import BlogPreview from "./slices/BlogPreview.astro";
import Work from "./slices/Work.astro";

interface Props {
  slices: any[];
}

const { slices } = Astro.props;
---

{
  slices.map((slice) => {
    switch (slice.type) {
      case "home-hero":
        return <HomeHero slice={slice} />;
      case "blog-section":
        return <BlogPreview slice={slice} />;
      case "work-section":
        return <Work slice={slice} />;
      default:
        return null;
    }
  })
}
