---
import { getCollection } from "astro:content";
import ArticlePreview from "../ArticlePreview.astro";

interface Props {
  slice: {
    title: string;
    articleCount: number;
    link: { text: string; url: string };
  };
}

const { slice } = Astro.props;

const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, slice.articleCount || 4);
---

<section class="container py-12">
  <p class="uppercase tracking-wide text-blog-500 font-bold mb-6 text-lg">
    {slice.title}
  </p>
  <div class="flex flex-col gap-8">
    {
      posts.map((post) => (
        <ArticlePreview
          title={post.data.title}
          slug={post.data.slug}
          description={post.data.description}
        />
      ))
    }
  </div>
  <a
    href={slice.link.url}
    class="mt-6 px-4 py-2 text-blog-800 dark:text-blog-100 bg-blog-200 dark:bg-blog-800 text-lg font-semibold rounded-lg inline-block hover:shadow"
  >
    {slice.link.text}
    <svg
      class="inline -mt-[2px] ml-1"
      width="1em"
      height="1em"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
        points="12 5 19 12 12 19"></polyline></svg
    >
  </a>
</section>
