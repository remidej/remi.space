---
import SocialButtons from "./SocialButtons.astro";
import global from "../data/global.json";
---

<footer class="py-12 bg-gray-100 dark:bg-gray-800">
  <div
    class="container mx-auto flex flex-col md:flex-row md:justify-between"
  >
    <!-- Contact -->
    <div>
      <nav class="flex flex-row items-center my-2 mx-auto">
        <SocialButtons socialNetworks={global.footerSocialNetworks} />
      </nav>
      <p
        class="text-2xl md:text-3xl font-semibold text-gray-700 dark:text-gray-300 mt-6 md:mt-0"
      >
        {global.email}
      </p>
    </div>
    <!-- Lists of links -->
    <div class="flex flex-row mt-6 md:mt-0">
      {
        global.footerSections.map((footerSection) => (
          <div class="w-1/2 md:w-auto md:mr-16">
            <p class="uppercase tracking-wide font-semibold text-gray-500">
              {footerSection.title}
            </p>
            <ul>
              {footerSection.links.map((link) => (
                <li class="mt-2">
                  <a
                    href={link.url}
                    target={link.openInNewTab ? "_blank" : "_self"}
                  >
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</footer>
